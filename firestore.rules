// firestore.rules
// ============================================================
// Firestore Security Rules for Mentoria360
// Deploy with: firebase deploy --only firestore:rules
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ───────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return isSignedIn() && getUserData().role == 'superadmin';
    }

    function isAdmin() {
      return isSignedIn() && getUserData().role == 'admin';
    }

    function isAdminOf(coachingId) {
      return isAdmin() && getUserData().coachingId == coachingId;
    }

    function isApprovedStudentOf(coachingId) {
      return isSignedIn()
        && getUserData().role == 'student'
        && getUserData().coachingId == coachingId
        && getUserData().status == 'approved';
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isMemberOf(coachingId) {
      return isAdminOf(coachingId) || isApprovedStudentOf(coachingId) || isSuperAdmin();
    }

    // ── /users collection ──────────────────────────────────────
    match /users/{userId} {
      allow read: if isOwner(userId) || isSuperAdmin() || isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId)
        || isSuperAdmin()
        || (isAdmin() && resource.data.coachingId == getUserData().coachingId);
      allow delete: if isSuperAdmin();
    }

    // ── /tutors collection ─────────────────────────────────────
    // PUBLIC: anyone can read tutor profiles (shown on landing page)
    match /tutors/{tutorUid} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == tutorUid;
      allow update: if isOwner(tutorUid) || isSuperAdmin();
      allow delete: if isSuperAdmin();

      match /reviews/{reviewId} {
        allow read:   if true;
        allow create: if isSignedIn();
        allow update: if isSuperAdmin();
        allow delete: if isSuperAdmin();
      }

      match /paymentMethods/{methodId} {
        allow read:   if isSignedIn();
        allow create: if isOwner(tutorUid) || isSuperAdmin();
        allow update: if isOwner(tutorUid) || isSuperAdmin();
        allow delete: if isOwner(tutorUid) || isSuperAdmin();
      }
    }

    // ── /coachings collection ──────────────────────────────────
    match /coachings/{coachingId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isAdminOf(coachingId) || isSuperAdmin();
      allow delete: if isSuperAdmin();

      match /joinRequests/{requestId} {
        allow read:   if isAdminOf(coachingId) || isSuperAdmin();
        allow create: if isSignedIn();
        allow update: if isAdminOf(coachingId) || isSuperAdmin();
        allow delete: if isAdminOf(coachingId) || isSuperAdmin();
      }

      match /students/{studentId} {
        allow read:  if isAdminOf(coachingId) || isApprovedStudentOf(coachingId) || isSuperAdmin();
        allow write: if isAdminOf(coachingId) || isSuperAdmin();
      }

      match /fees/{feeId} {
        allow read: if isAdminOf(coachingId)
          || isSuperAdmin()
          || (isApprovedStudentOf(coachingId) && resource.data.studentId == request.auth.uid);
        allow write: if isAdminOf(coachingId) || isSuperAdmin();
      }

      match /classes/{classId} {
        allow read:  if isAdminOf(coachingId) || isApprovedStudentOf(coachingId) || isSuperAdmin();
        allow write: if isAdminOf(coachingId) || isSuperAdmin();
      }

      match /workshops/{workshopId} {
        allow read:   if isAdminOf(coachingId) || isApprovedStudentOf(coachingId) || isSuperAdmin();
        allow create: if isAdminOf(coachingId) || isSuperAdmin();
        allow update: if isAdminOf(coachingId) || isApprovedStudentOf(coachingId) || isSuperAdmin();
        allow delete: if isAdminOf(coachingId) || isSuperAdmin();
      }

      match /transactions/{txId} {
        allow read:  if isAdminOf(coachingId) || isSuperAdmin();
        allow write: if isAdminOf(coachingId) || isSuperAdmin();
      }

      match /announcements/{announcementId} {
        allow read:   if isMemberOf(coachingId);
        allow create: if isAdminOf(coachingId) || isSuperAdmin();
        allow update: if isAdminOf(coachingId) || isSuperAdmin();
        allow delete: if isAdminOf(coachingId) || isSuperAdmin();
      }

      match /attendance/{date} {
        allow read:  if isAdminOf(coachingId) || isApprovedStudentOf(coachingId) || isSuperAdmin();
        allow write: if isAdminOf(coachingId) || isSuperAdmin();
      }

      match /materials/{materialId} {
        allow read:   if isMemberOf(coachingId);
        allow create: if isAdminOf(coachingId) || isSuperAdmin();
        allow update: if isAdminOf(coachingId) || isSuperAdmin();
        allow delete: if isAdminOf(coachingId) || isSuperAdmin();
      }

      match /homework/{homeworkId} {
        allow read:   if isMemberOf(coachingId);
        allow create: if isAdminOf(coachingId) || isSuperAdmin();
        allow update: if isAdminOf(coachingId) || isSuperAdmin()
          || (isApprovedStudentOf(coachingId)
              && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['submissions']));
        allow delete: if isAdminOf(coachingId) || isSuperAdmin();
      }

      match /tests/{testId} {
        allow read:   if isMemberOf(coachingId);
        allow create: if isAdminOf(coachingId) || isSuperAdmin();
        allow update: if isAdminOf(coachingId) || isSuperAdmin()
          || (isApprovedStudentOf(coachingId)
              && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['attemptCount']));
        allow delete: if isAdminOf(coachingId) || isSuperAdmin();
      }

      match /testAttempts/{attemptId} {
        allow read:   if isAdminOf(coachingId) || isSuperAdmin()
          || (isApprovedStudentOf(coachingId) && resource.data.studentId == request.auth.uid);
        allow create: if isApprovedStudentOf(coachingId);
        allow update: if isSuperAdmin();
        allow delete: if isAdminOf(coachingId) || isSuperAdmin();
      }

      // ── Reviews (public read, signed-in write)
      match /reviews/{reviewId} {
        allow read:   if true;
        allow create: if isSignedIn();
        allow update: if isSuperAdmin();
        allow delete: if isSuperAdmin();
      }

      // ── Payment methods (signed-in read, admin write)
      match /paymentMethods/{methodId} {
        allow read:   if isSignedIn();
        allow create: if isAdminOf(coachingId) || isSuperAdmin();
        allow update: if isAdminOf(coachingId) || isSuperAdmin();
        allow delete: if isAdminOf(coachingId) || isSuperAdmin();
      }
    }
  }
}
